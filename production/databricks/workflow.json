{
  "_comment": "SemestaBank Q1(c) orchestration — Databricks Workflows variant of the local Airflow DAG (Final_Answer/local/q1_pipeline/airflow/dags/account_snapshot_dag.py). Deploy with: databricks jobs create --json @workflow.json. Satisfies: trigger credit scoring after snapshot succeeds; retry each task up to 3x; alert on-call after retries exhausted; 30-minute SLA on the snapshot task.",
  "name": "semestabank_lakehouse_pipeline",
  "tags": { "team": "data-eng", "domain": "lakehouse", "question": "q1c" },
  "schedule": {
    "quartz_cron_expression": "0 0 2 * * ?",
    "timezone_id": "Asia/Jakarta",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "parameters": [
    { "name": "snapshot_date", "default": "" },
    { "name": "dq_fail_hard", "default": "1" }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "elt_cluster",
      "new_cluster": {
        "spark_version": "15.4.x-scala2.12",
        "node_type_id": "m5d.xlarge",
        "data_security_mode": "USER_ISOLATION",
        "autoscale": { "min_workers": 2, "max_workers": 8 },
        "aws_attributes": { "availability": "SPOT_WITH_FALLBACK", "first_on_demand": 1 }
      }
    }
  ],
  "tasks": [
    {
      "task_key": "bronze_ingest",
      "job_cluster_key": "elt_cluster",
      "spark_python_task": { "python_file": "/Workspace/semestabank/jobs/bronze_ingest_job.py" },
      "max_retries": 3,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": true
    },
    {
      "task_key": "account_snapshot",
      "depends_on": [{ "task_key": "bronze_ingest" }],
      "job_cluster_key": "elt_cluster",
      "spark_python_task": {
        "python_file": "/Workspace/semestabank/jobs/account_snapshot_job.py",
        "parameters": ["{{job.parameters.snapshot_date}}", "{{job.parameters.dq_fail_hard}}"]
      },
      "max_retries": 3,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": true,
      "timeout_seconds": 1800,
      "health": {
        "rules": [
          { "metric": "RUN_DURATION_SECONDS", "op": "GREATER_THAN", "value": 1800 }
        ]
      }
    },
    {
      "task_key": "gold_views",
      "depends_on": [{ "task_key": "account_snapshot" }],
      "pipeline_task": { "pipeline_id": "${dlt_gold_pipeline_id}" }
    },
    {
      "task_key": "trigger_credit_scoring",
      "depends_on": [{ "task_key": "gold_views" }],
      "run_job_task": { "job_id": "${credit_scoring_job_id}" }
    }
  ],
  "email_notifications": {
    "on_failure": ["data-oncall@semestabank.id"],
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {
    "on_failure": [{ "id": "${pagerduty_webhook_id}" }]
  },
  "notification_settings": { "no_alert_for_canceled_runs": true }
}
