# Copy this file to .env (the real .env should never be committed).
# Backwards compatible with prod: in AWS these come from Secrets Manager /
# Databricks dbutils.secrets / Airflow connections - never from code.

# ── Source database (optional, for PostgreSQL-based SQL exploration) ──
JDBC_URL=jdbc:postgresql://postgres:5432/semestabank
JDBC_USER=etl_user
JDBC_PASSWORD=etl_pass123

# ── MinIO lakehouse buckets ──
# Bronze = raw ingested CSVs as Parquet
S3_BUCKET_BRONZE=semestabank-bronze
# Silver = cleaned, partitioned data (Q1 output)
S3_BUCKET=semestabank-silver
S3_PATH=account_snapshots
# Gold = business-ready views (Q2 output)
S3_BUCKET_GOLD=semestabank-gold

# ── MinIO credentials (local = minioadmin / minioadmin123) ──
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
